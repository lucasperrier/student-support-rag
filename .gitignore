!data/vector_db/.gitkeep

# Generated DB / leads / memory (should never be committed)
data/*.db
data/*.sqlite*
data/leads.json
data/*memory*.json
data/vector_index.json

# Vector indexes (legacy + canonical)
data/*.faiss
data/*metadata*.json
data/vector_db/*.faiss
data/vector_db/*metadata*.json
data/vector_db/index.faiss
data/vector_db/index_metadata.json