# Copy to .env and adjust as needed. Safe defaults are shown below.

# --- Local LLM (Ollama) ---
# Model used by the agents for answer generation.
# Retrieval works WITHOUT Ollama; only answer generation needs it.
OLLAMA_MODEL=llama2
# Address of the Ollama server (read by the ollama python client).
OLLAMA_HOST=http://127.0.0.1:11434

# --- Orchestrator ---
# Routing strategy: "rules" (default, deterministic) or "llm" (LLM classifier).
ESILV_ORCHESTRATION_MODE=rules
